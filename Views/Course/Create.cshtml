@model UniversityApp.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<h2>Create Course</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold mb-1"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Degree" class="control-label fw-bold mb-1"></label>
                <input asp-for="Degree" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Degree" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="MinDegree" class="control-label fw-bold mb-1"></label>
                <input asp-for="MinDegree" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="MinDegree" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Hrs" class="control-label fw-bold mb-1"></label>
                <input asp-for="Hrs" class="form-control" type="number" />
                <span asp-validation-for="Hrs" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="DepartmentId" class="control-label fw-bold mb-1"></label>
                <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.Departments">
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-success">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>