@model UniversityApp.Models.CrsResult

@{
    ViewData["Title"] = "Delete Result";
}

<h2 class="text-danger mb-3"><i class="bi bi-exclamation-octagon-fill"></i> Delete Course Result</h2>
<h3 class="text-muted mb-4">Are you sure you want to remove this student's result record?</h3>
<hr />

<div class="card border-danger mb-4 shadow-sm">
    <div class="card-header bg-danger text-white">
        <h5 class="card-title mb-0"><i class="bi bi-trash3"></i> Review Result Record Before Deletion</h5>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Student Name:</div>
            <div class="col-md-9 text-danger fw-bold">@(Model.Trainee?.Name ?? "N/A")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Course:</div>
            <div class="col-md-9">@(Model.Course?.Name ?? "N/A")</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Recorded Degree:</div>
            <div class="col-md-9 fw-bold">@Model.Degree</div>
        </div>

        <div class="alert alert-danger mb-0 mt-3 py-2">
            <i class="bi bi-info-circle-fill"></i> Warning: Deleting this record will completely remove the student's grade for this course from the system.
        </div>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger px-4 me-2">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
</form>