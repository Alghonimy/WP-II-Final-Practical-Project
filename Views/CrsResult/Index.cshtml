@model IEnumerable<UniversityApp.Models.CrsResult>

@{
    ViewData["Title"] = "Course Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Student Results</h2>
    <a asp-action="Create" class="btn btn-primary">Record New Result</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by trainee or course name..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Trainee Name</th>
            <th>Course Name</th>
            <th>Scored Degree</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var isPassed = item.Degree >= (item.Course?.MinDegree ?? 50);
            <tr>
                <td>@(item.Trainee?.Name ?? "N/A")</td>
                <td>@(item.Course?.Name ?? "N/A")</td>
                <td>@item.Degree</td>
                <td>
                    <span class="badge @(isPassed ? "bg-success" : "bg-danger")">
                        @(isPassed ? "Passed" : "Failed")
                    </span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>