@model UniversityApp.Models.CrsResult

@{
    ViewData["Title"] = "Result Details";
    // حساب حالة الطالب بناءً على الحد الأدنى للنجاح المخزن في جدول الكورس (الافتراضي 50 إذا لم يوجد)
    var minDegree = Model.Course?.MinDegree ?? 50;
    var isPassed = Model.Degree >= minDegree;
}

<h2 class="mb-3">Course Result Details</h2>
<hr />

<div class="card mb-4 shadow-sm border-0 bg-light">
    <div class="card-body p-4">
        <h3 class="card-title text-primary fw-bold mb-4">
            <i class="bi bi-journal-check"></i> Academic Record
        </h3>

        <div class="row mb-3 py-2 border-bottom">
            <div class="col-sm-3 fw-bold text-secondary">Trainee Name:</div>
            <div class="col-sm-9 fs-5 fw-semibold">@(Model.Trainee?.Name ?? "N/A")</div>
        </div>

        <div class="row mb-3 py-2 border-bottom">
            <div class="col-sm-3 fw-bold text-secondary">Course Name:</div>
            <div class="col-sm-9 fs-5">@(Model.Course?.Name ?? "N/A")</div>
        </div>

        <div class="row mb-3 py-2 border-bottom">
            <div class="col-sm-3 fw-bold text-secondary">Course Total Degree:</div>
            <div class="col-sm-9">@(Model.Course?.Degree ?? 100)</div>
        </div>

        <div class="row mb-3 py-2 border-bottom">
            <div class="col-sm-3 fw-bold text-secondary">Minimum Passing Degree:</div>
            <div class="col-sm-9 text-muted">@minDegree</div>
        </div>

        <div class="row mb-3 py-2 border-bottom">
            <div class="col-sm-3 fw-bold text-secondary">Scored Degree:</div>
            <div class="col-sm-9 fs-5 fw-bold text-dark">@Model.Degree</div>
        </div>

        <div class="row mb-2 py-2">
            <div class="col-sm-3 fw-bold text-secondary">Final Status:</div>
            <div class="col-sm-9">
                <span class="badge @(isPassed ? "bg-success" : "bg-danger") px-3 py-2 fs-6">
                    @(isPassed ? "Passed" : "Failed")
                </span>
            </div>
        </div>
    </div>
</div>

<div class="form-group">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 me-2">Edit Result</a>
    <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
</div>