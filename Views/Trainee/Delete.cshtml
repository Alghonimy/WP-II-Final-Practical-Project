@model UniversityApp.Models.Trainee

@{
    ViewData["Title"] = "Delete Trainee";
}

<h2 class="text-danger mb-3"><i class="bi bi-exclamation-triangle-fill"></i> Delete Trainee Record</h2>
<h3 class="text-muted mb-4">Are you sure you want to permanently delete this trainee?</h3>
<hr />

<div class="card border-danger mb-4 shadow-sm">
    <div class="card-header bg-danger text-white">
        <h5 class="card-title mb-0"><i class="bi bi-shield-alert"></i> Review Student File Before Deletion</h5>
    </div>
    <div class="card-body">
        <h4 class="text-danger fw-bold mb-3">@Model.Name</h4>
        <p class="card-text"><strong>Grade:</strong> @Model.Grade</p>
        <p class="card-text"><strong>Address:</strong> @Model.Address</p>
        <p class="card-text"><strong>Department:</strong> @(Model.Department?.Name ?? "No Department")</p>

        <div class="alert alert-warning mb-0 mt-3 py-2">
            <i class="bi bi-info-circle-fill"></i> <strong>Notice:</strong> This will also remove any related academic results or dependencies attached to this trainee.
        </div>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger px-4 me-2">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
</form>